# =============================================================================
# FTP Deployment Credentials — TEMPLATE (committed)
# =============================================================================
# Copy this file to `.env.deploy` and fill in real values.
# `.env.deploy` is gitignored and must NEVER be committed.
# =============================================================================

# --- Connection ---
FTP_HOST="ftp.example.com"
FTP_USER="your-username"
FTP_PASS="your-password"
FTP_PORT="21"
FTP_PROTOCOL="ftps"   # ftp | ftps | sftp

# --- Remote layout ---
FTP_REMOTE_DIR="/www/"

# --- Files to PRESERVE on the server (comma-separated, relative to FTP_REMOTE_DIR) ---
FTP_PRESERVE="signature-mail.html"

# --- Deployment mode ---
# "preview" → deploys to FTP_REMOTE_DIR/preview/
# "root"    → deploys at FTP_REMOTE_DIR (replaces existing site)
DEPLOY_MODE="preview"
