---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Contact" description="Contactez la Cie Fusibles & Dentelles pour programmer le spectacle El Camino.">
  <Header />

  <section class="py-16 px-4" style="background-color: var(--color-bg-warm);">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest mb-2 text-center" style="color: var(--color-secondary);">
        Contact
      </p>
      <h1 class="text-4xl md:text-5xl text-center mb-4" style="font-family: var(--font-heading); color: var(--color-primary);">
        Parlons de votre projet
      </h1>
      <p class="text-center text-lg mb-12 max-w-2xl mx-auto" style="color: var(--color-text-light);">
        Vous souhaitez programmer El Camino ? N'hésitez pas à nous contacter.
      </p>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- Coordonnées directes -->
        <div class="bg-white rounded-xl p-8 shadow-sm">
          <h2 class="text-xl font-semibold mb-6" style="color: var(--color-primary); font-family: var(--font-heading);">
            Nous écrire
          </h2>
          <ul class="space-y-4">
            <li>
              <p class="text-sm uppercase tracking-wider mb-1" style="color: var(--color-text-muted);">Email</p>
              <a href="mailto:bonjour@fusiblesetdentelles.fr" class="text-base hover:underline" style="color: var(--color-primary);">
                bonjour@fusiblesetdentelles.fr
              </a>
            </li>
            <li>
              <p class="text-sm uppercase tracking-wider mb-1" style="color: var(--color-text-muted);">Communication</p>
              <a href="mailto:communication@fusiblesetdentelles.fr" class="text-base hover:underline" style="color: var(--color-primary);">
                communication@fusiblesetdentelles.fr
              </a>
            </li>
            <li>
              <p class="text-sm uppercase tracking-wider mb-1" style="color: var(--color-text-muted);">Téléphone</p>
              <a href="tel:+33638795035" class="text-base" style="color: var(--color-text);">
                06 38 79 50 35
              </a>
            </li>
            <li>
              <p class="text-sm uppercase tracking-wider mb-1" style="color: var(--color-text-muted);">Adresse</p>
              <p style="color: var(--color-text);">100 Avenue de Colmar<br />68100 Mulhouse</p>
            </li>
          </ul>
        </div>

        <!-- Réseaux + dossier -->
        <div class="space-y-8">
          <div class="bg-white rounded-xl p-8 shadow-sm">
            <h2 class="text-xl font-semibold mb-4" style="color: var(--color-primary); font-family: var(--font-heading);">
              Suivez-nous
            </h2>
            <div class="flex gap-4">
              <a
                href="https://fr-fr.facebook.com/fusiblesetdentelles/"
                target="_blank"
                rel="noopener noreferrer"
                class="px-5 py-2.5 rounded border transition-all hover:opacity-80"
                style="border-color: var(--color-secondary); color: var(--color-secondary);"
              >
                Facebook
              </a>
              <a
                href="https://instagram.com/fusiblesetdentelles/"
                target="_blank"
                rel="noopener noreferrer"
                class="px-5 py-2.5 rounded border transition-all hover:opacity-80"
                style="border-color: var(--color-primary); color: var(--color-primary);"
              >
                Instagram
              </a>
            </div>
          </div>

          <div class="bg-white rounded-xl p-8 shadow-sm">
            <h2 class="text-xl font-semibold mb-4" style="color: var(--color-primary); font-family: var(--font-heading);">
              Dossier du spectacle
            </h2>
            <p class="text-sm mb-4" style="color: var(--color-text-light);">
              Retrouvez toutes les informations sur El Camino dans notre dossier complet.
            </p>
            <a
              href={`${base}documents/EL-CAMINO-Dossier.pdf`}
              target="_blank"
              class="inline-block px-6 py-3 rounded font-semibold text-white transition-all hover:opacity-90"
              style="background-color: var(--color-primary);"
            >
              Télécharger le dossier (PDF)
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
