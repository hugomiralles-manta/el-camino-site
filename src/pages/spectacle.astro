---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import PageSection from '../components/layout/PageSection.astro';
import SectionLabel from '../components/ui/SectionLabel.astro';
import EditorialQuote from '../components/ui/EditorialQuote.astro';
import TechnicalSheet from '../components/content/TechnicalSheet.astro';
import Button from '../components/ui/Button.astro';
import { show } from '../content/show';
import { creativeTeam } from '../content/artists';
import { company } from '../content/company';

const base = import.meta.env.BASE_URL;

// Build technical sheet items from content/show.ts (single source of truth)
const ficheItems = [
  { icon: '⏱', label: 'Durée', value: show.technicalSheet.duration },
  { icon: '🎭', label: 'Type', value: show.technicalSheet.type },
  { icon: '👥', label: 'Public', value: show.technicalSheet.audience },
  { icon: '📐', label: 'Espace scénique', value: show.technicalSheet.stage },
  { icon: '★', label: 'Sur le plateau', value: show.technicalSheet.onStage },
  { icon: '💡', label: 'Régie', value: show.technicalSheet.lighting },
  { icon: '€', label: 'Tarif', value: show.technicalSheet.pricing },
];
---

<BaseLayout
  title={show.title}
  description={`${show.title} — ${show.subtitle}. ${show.description} Avec Elisabeth von Buxhoeveden et Jean-Marc Miralles.`}
>
  <Header />

  <!-- Hero page — crimson band -->
  <section class="spectacle-hero">
    <div class="spectacle-hero__inner">
      <SectionLabel as="p" size="sm">{company.shortName}</SectionLabel>
      <h1 class="spectacle-hero__title">{show.title}</h1>
      <p class="spectacle-hero__tagline">
        {show.headline}<br />{show.headlineContd}
      </p>
    </div>
  </section>

  <!-- Synopsis -->
  <PageSection label="Synopsis" title="Un bout de chemin à partager" background="warm">
    <div class="synopsis">
      <p>Dans ce spectacle, vous partagez un bout de chemin avec Gabrielle et Juan.</p>
      <p>
        Gabrielle est une quinquagénaire phobique et insomniaque qui s'est mis en tête de faire
        Compostelle pour dépasser ses peurs et retrouver le sommeil.
      </p>
      <p>
        Juan est un musicien libre et insouciant qui va croiser la route de Gabrielle et la mettre
        face à ses limites bien malgré lui.
      </p>
      <p>
        <em>{show.title}</em> raconte le chemin de toutes celles et ceux qui se retrouvent à un
        carrefour de leur vie et décide de faire marcher leurs pieds plutôt que leur tête.
      </p>
      <p>{show.description}</p>
      <EditorialQuote>1h20 de chansons, de show et de kilomètres.</EditorialQuote>
    </div>
  </PageSection>

  <!-- Vidéos -->
  <PageSection label="Médias" title="Vidéos" background="white">
    <div class="videos-grid">
      <div class="video-item">
        <SectionLabel as="p" size="sm">Teaser</SectionLabel>
        <VideoEmbed videoId="OsuFC8ETyh4" title={`Teaser ${show.title}`} />
      </div>
      <div class="video-item">
        <SectionLabel as="p" size="sm">Medley</SectionLabel>
        <VideoEmbed videoId="YiCRAO-KXXA" title={`Medley ${show.title}`} />
      </div>
    </div>
  </PageSection>

  <!-- Fiche technique -->
  <PageSection label="Informations" title="Fiche technique" background="warm">
    <div class="fiche-wrapper">
      <TechnicalSheet items={ficheItems} />
    </div>
  </PageSection>

  <!-- Crédits -->
  <PageSection label="Équipe" title="Crédits" background="white">
    <ul class="credits">
      {creativeTeam.map(({ role, person }) => (
        <li class="credits__item">
          <p class="credits__role">{role}</p>
          <p class="credits__person">{person}</p>
        </li>
      ))}
    </ul>
  </PageSection>

  <!-- CTA dossier -->
  <section class="dossier-cta">
    <div class="dossier-cta__inner">
      <h2 class="dossier-cta__title">Dossier de présentation complet</h2>
      <p class="dossier-cta__subtitle">Pour les programmateurs et diffuseurs</p>
      <Button
        href={`${base}documents/EL-CAMINO-Dossier.pdf`}
        variant="primary"
        icon="⬇"
        external={true}
      >
        Télécharger le dossier complet
      </Button>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ---- Hero --------------------------------------------------------------- */
  .spectacle-hero {
    background-color: var(--color-primary);
    color: #ffffff;
    text-align: center;
    padding: var(--space-16) var(--space-5);
  }
  .spectacle-hero__inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .spectacle-hero__inner :global(.section-label) {
    color: rgba(255, 255, 255, 0.75);
  }
  .spectacle-hero__title {
    font-family: var(--font-family);
    font-style: italic;
    font-weight: var(--weight-normal);
    font-size: var(--text-3xl);
    line-height: var(--leading-tight);
    margin: var(--space-4) 0;
  }
  .spectacle-hero__tagline {
    font-family: var(--font-family);
    font-size: var(--text-md);
    opacity: 0.9;
    margin: 0;
    line-height: var(--leading-normal);
  }

  /* ---- Synopsis ----------------------------------------------------------- */
  .synopsis {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    font-family: var(--font-family);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }
  .synopsis p {
    margin: 0;
  }

  /* ---- Videos ------------------------------------------------------------- */
  .videos-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: 960px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .videos-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .video-item :global(.section-label) {
    margin-bottom: var(--space-3);
  }

  /* ---- Fiche technique wrapper -------------------------------------------- */
  .fiche-wrapper {
    max-width: 820px;
    margin: 0 auto;
  }

  /* ---- Credits list ------------------------------------------------------- */
  .credits {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }
  .credits__item {
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }
  .credits__item:last-child {
    border-bottom: none;
  }
  .credits__role {
    font-family: var(--font-family);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-secondary);
    font-weight: var(--weight-bold);
    margin: 0 0 var(--space-1);
  }
  .credits__person {
    font-family: var(--font-family);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0;
  }

  /* ---- Dossier CTA footer band -------------------------------------------- */
  .dossier-cta {
    background-color: var(--color-bg-warm);
    text-align: center;
    padding: var(--space-12) var(--space-5);
  }
  .dossier-cta__inner {
    max-width: 560px;
    margin: 0 auto;
  }
  .dossier-cta__title {
    font-family: var(--font-family);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--color-text);
    font-weight: var(--weight-normal);
    margin: 0 0 var(--space-3);
  }
  .dossier-cta__subtitle {
    font-family: var(--font-family);
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin: 0 0 var(--space-6);
  }
</style>
