---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const datesPassees = [
  { date: '26.04.2024', lieu: 'Vendredis de la Chartreuse', ville: 'Molsheim (67)' },
  { date: '14.02.2024', lieu: "L'Aronde", ville: 'Riedisheim (68)' },
  { date: '28.01.2024', lieu: 'Foyer Sainte Geneviève', ville: 'Mulhouse (68)' },
];
---

<BaseLayout
  title="Calendrier"
  description="Prochaines dates d'El Camino — Cie Fusibles & Dentelles. Retrouvez les dates de représentations."
>
  <Header />

  <!-- Hero -->
  <section class="py-14 px-4 text-white text-center" style="background-color: var(--color-primary);">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-3" style="font-family: var(--font-heading);">
        Le calendrier survolté
      </h1>
      <p class="text-lg opacity-90">de Fusibles & Dentelles</p>
    </div>
  </section>

  <!-- Prochaines dates -->
  <section class="py-16 px-4" style="background-color: var(--color-bg-warm);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl mb-8" style="font-family: var(--font-heading); color: var(--color-primary);">
        Prochaines dates
      </h2>

      <div
        class="rounded-xl border-2 border-dashed p-10 text-center"
        style="border-color: var(--color-secondary); background-color: white;"
      >
        <p class="font-semibold text-lg mb-2" style="font-family: var(--font-heading); color: var(--color-text);">
          Dates à venir... Restez connectés !
        </p>
        <p class="text-sm mb-6" style="color: var(--color-text-light);">
          Vous souhaitez programmer El Camino dans votre structure ?
        </p>
        <a
          href={`${base}contact`}
          class="inline-block px-6 py-3 rounded-full font-semibold text-white transition-all hover:scale-105"
          style="background-color: var(--color-primary);"
        >
          Contactez-nous
        </a>
      </div>
    </div>
  </section>

  <!-- Dates passées -->
  <section class="py-12 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-xl mb-6" style="font-family: var(--font-heading); color: var(--color-text);">
        Quelques dates passées
      </h2>
      <div class="space-y-3">
        {datesPassees.map(({ date, lieu, ville }) => (
          <div
            class="flex items-center justify-between p-4 rounded-lg opacity-70"
            style="background-color: var(--color-bg-warm);"
          >
            <div>
              <p class="font-semibold text-sm" style="color: var(--color-text);">{lieu}</p>
              <p class="text-xs" style="color: var(--color-text-muted);">{ville}</p>
            </div>
            <p class="text-sm tabular-nums" style="color: var(--color-text-light);">{date}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA programmateur -->
  <section class="py-12 px-4 text-center" style="background-color: var(--color-secondary);">
    <div class="max-w-2xl mx-auto text-white">
      <p class="font-semibold text-lg mb-2">Vous souhaitez programmer El Camino ?</p>
      <p class="opacity-90 mb-6 text-sm">
        Contactez-nous pour discuter de votre projet. Dossier de présentation disponible sur demande.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={`${base}contact`}
          class="px-6 py-3 rounded-full bg-white font-semibold text-sm transition-all hover:scale-105"
          style="color: var(--color-secondary);"
        >
          Nous contacter
        </a>
        <a
          href={`${base}documents/EL-CAMINO-Dossier.pdf`}
          download
          class="px-6 py-3 rounded-full border-2 border-white text-white font-semibold text-sm transition-all hover:bg-white hover:text-[var(--color-secondary)]"
        >
          Télécharger le dossier
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
