---
import '../styles/global.css';

const base = import.meta.env.BASE_URL;

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "El Camino — Spectacle musico-théâtral de la Cie Fusibles & Dentelles",
  image = `${base}images/PaysageFD.jpeg`
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image.startsWith('/') ? image : `/${image}`, Astro.site).toString();
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} — Cie Fusibles & Dentelles</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} — Cie Fusibles & Dentelles`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:locale" content="fr_FR" />

    <!--
      Font stack: Palatino / Georgia / Times New Roman / serif — all system fonts,
      no Google Fonts fetch needed. Single source of truth: --font-family in tokens.css.
    -->

    <link rel="icon" type="image/png" href="/el-camino-site/logo/LOGO-COULEUR.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
