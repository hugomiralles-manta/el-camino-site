---
import HeartMotif from './HeartMotif.astro';

interface Props {
  color?: string;
}
const { color } = Astro.props;
---
<div class="divider">
  <div class="divider__line"></div>
  <span class="divider__heart">
    <HeartMotif color={color} size="20px" />
  </span>
</div>

<style>
  .divider {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: var(--space-8) 0;
  }
  .divider__line {
    width: 100%;
    border-top: 1px solid var(--color-border);
  }
  .divider__heart {
    position: absolute;
    background-color: var(--color-bg-white);
    padding: 0 var(--space-2);
    display: flex;
    align-items: center;
  }
</style>
