---
interface Props {
  icon: string;
  label: string;
  value: string;
}
const { icon, label, value } = Astro.props;
---
<div class="icon-text">
  <span class="icon-text__icon" aria-hidden="true">{icon}</span>
  <span class="icon-text__label">{label}</span>
  <span class="icon-text__value">{value}</span>
</div>

<style>
  .icon-text {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .icon-text__icon {
    font-size: var(--text-base);
    flex-shrink: 0;
  }
  .icon-text__label {
    font-family: var(--font-family);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-weight: var(--weight-bold);
    flex-shrink: 0;
  }
  .icon-text__value {
    font-family: var(--font-family);
    font-size: var(--text-base);
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .icon-text {
      flex-direction: column;
      gap: var(--space-1);
    }
  }
</style>
