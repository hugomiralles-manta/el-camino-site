---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  icon?: string;
  external?: boolean;
}
const { href, variant = 'primary', icon, external } = Astro.props;
const classes = `btn btn--${variant}`;
---
<a
  href={href}
  class={classes}
  {...(external && { target: '_blank', rel: 'noopener noreferrer' })}
>
  {icon && <span class="btn__icon">{icon}</span>}
  <slot />
</a>

<style>
  .btn {
    display: inline-block;
    padding: 11px 24px;
    font-family: var(--font-family);
    font-size: 14px;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: opacity 0.2s, color 0.2s;
    cursor: pointer;
  }
  .btn__icon { margin-right: 6px; }

  .btn--primary {
    background-color: var(--color-primary);
    color: #fff;
  }
  .btn--primary:hover { background-color: var(--color-primary-dark); }

  .btn--secondary {
    background-color: var(--color-secondary);
    color: #fff;
  }
  .btn--secondary:hover { background-color: var(--color-secondary-dark); }

  .btn--outline {
    border: 1px solid var(--color-text-muted);
    color: var(--color-text-light);
    background: transparent;
  }
  .btn--outline:hover { border-color: var(--color-text-light); }

  .btn--ghost {
    background: transparent;
    color: var(--color-text);
    padding-left: 0;
    padding-right: 0;
  }
  .btn--ghost:hover { text-decoration: underline; }
</style>
