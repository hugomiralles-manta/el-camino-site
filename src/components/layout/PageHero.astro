---
import SectionLabel from '../ui/SectionLabel.astro';
import EditorialQuote from '../ui/EditorialQuote.astro';

interface Props {
  label: string;
  title: string;
  subtitle?: string;
  tagline?: string;
  banner?: string;
  bannerAlt?: string;
  variant?: 'editorial' | 'cinematic';
  imageMode?: 'banner' | 'fullbleed';
  heroSize?: 'full' | 'compact';
}

const {
  label,
  title,
  subtitle,
  tagline,
  banner,
  bannerAlt = '',
  variant = 'editorial',
  imageMode = 'banner',
  heroSize = 'full',
} = Astro.props;
---

{variant === 'cinematic' ? (
  <section
    class={`page-hero page-hero--cinematic page-hero--${heroSize}`}
    style={banner ? `background-image: url('${banner}')` : undefined}
  >
    <div class="page-hero__overlay"></div>
    <div class="page-hero__cinematic-content">
      <SectionLabel>{label}</SectionLabel>
      <h1 class="page-hero__title page-hero__title--cinematic">{title}</h1>
      {subtitle && <p class="page-hero__subtitle page-hero__subtitle--cinematic">{subtitle}</p>}
      {tagline && <EditorialQuote>{tagline}</EditorialQuote>}
      <slot />
    </div>
  </section>
) : (
  <section class={`page-hero page-hero--editorial page-hero--${heroSize}`}>
    <SectionLabel>{label}</SectionLabel>
    <h1 class="heading-editorial page-hero__title">{title}</h1>
    {subtitle && <p class="page-hero__subtitle">{subtitle}</p>}
    {tagline && <EditorialQuote>{tagline}</EditorialQuote>}
    <slot />
    {banner && heroSize !== 'compact' && (
      <img
        src={banner}
        alt={bannerAlt}
        class={`page-hero__banner${imageMode === 'fullbleed' ? ' page-hero__banner--fullbleed' : ''}`}
      />
    )}
  </section>
)}

<style>
  /* ---- Base ---------------------------------------------------------------- */
  .page-hero {
    padding: var(--space-10) var(--space-10) var(--space-5);
    max-width: var(--width-page);
    margin: 0 auto;
  }

  .page-hero--compact {
    padding: var(--space-6) var(--space-10) var(--space-4);
  }

  /* ---- Editorial variant -------------------------------------------------- */
  .page-hero--editorial .page-hero__title {
    font-size: var(--text-2xl);
    margin-top: var(--space-4);
  }

  @media (min-width: 768px) {
    .page-hero--editorial.page-hero--full .page-hero__title {
      font-size: var(--text-3xl);
    }
  }

  .page-hero__subtitle {
    font-family: var(--font-family);
    font-size: var(--text-sm);
    color: var(--color-secondary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin: var(--space-2) 0 var(--space-5);
  }

  /* Banner image (editorial mode) */
  .page-hero__banner {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin-top: var(--space-5);
  }

  .page-hero__banner--fullbleed {
    border-radius: 0;
    margin-left: calc(-1 * var(--space-10));
    width: calc(100% + 2 * var(--space-10));
  }

  /* ---- Cinematic variant -------------------------------------------------- */
  .page-hero--cinematic {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 0;
    max-width: 100%;
  }

  .page-hero--cinematic.page-hero--compact {
    min-height: 40vh;
  }

  /* Warm editorial overlay — no black, light tonal treatment */
  .page-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(244, 241, 237, 0.15), rgba(191, 39, 80, 0.25));
    pointer-events: none;
  }

  .page-hero__cinematic-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #ffffff;
    padding: var(--space-10);
    max-width: var(--width-page);
    width: 100%;
    margin: 0 auto;
  }

  .page-hero__title--cinematic {
    font-family: var(--font-family);
    font-style: italic;
    font-weight: var(--weight-normal);
    color: #ffffff;
    font-size: var(--text-2xl);
    line-height: var(--leading-tight);
    margin: var(--space-4) 0;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }

  @media (min-width: 768px) {
    .page-hero--cinematic.page-hero--full .page-hero__title--cinematic {
      font-size: var(--text-3xl);
    }
  }

  .page-hero__subtitle--cinematic {
    font-family: var(--font-family);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.85);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin: var(--space-2) 0 var(--space-5);
  }

  /* Cinematic: editorial quote in white */
  .page-hero--cinematic :global(.editorial-quote) {
    color: rgba(255, 255, 255, 0.9);
    border-left-color: rgba(255, 255, 255, 0.6);
    text-align: left;
    max-width: 540px;
    margin: 0 auto var(--space-6);
  }

  /* Cinematic: section label in white/translucent */
  .page-hero--cinematic :global(.section-label) {
    color: rgba(255, 255, 255, 0.75);
  }

  /* Responsive padding */
  @media (max-width: 640px) {
    .page-hero {
      padding: var(--space-6) var(--space-5) var(--space-4);
    }
    .page-hero__cinematic-content {
      padding: var(--space-6) var(--space-5);
    }
    .page-hero__banner--fullbleed {
      margin-left: calc(-1 * var(--space-5));
      width: calc(100% + 2 * var(--space-5));
    }
  }
</style>
