---
import IconText from '../ui/IconText.astro';

interface Item {
  icon: string;
  label: string;
  value: string;
}

interface Props {
  items: Item[];
}
const { items } = Astro.props;
---

<div class="technical-sheet">
  {items.map((item) => (
    <div class="technical-sheet__row">
      <IconText icon={item.icon} label={item.label} value={item.value} />
    </div>
  ))}
</div>

<style>
  .technical-sheet {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5) var(--space-8);
    width: 100%;
  }

  .technical-sheet__row {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-4);
  }

  @media (max-width: 640px) {
    .technical-sheet {
      grid-template-columns: 1fr;
    }
  }
</style>
